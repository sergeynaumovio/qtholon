#!/usr/bin/env qtloader6

[holon]
class = HolonDesktop
geometry = QByteArray(AdnQywADAAAAAAAwAAAEigAABDgAAAdsAAAAMAAABIoAAAQ4AAAHbAAAAAEAAAAABLAAAAAwAAAEigAABDgAAAds)
saveShortcut = Ctrl+S
sidebarMoveShortcut = Alt+M
startTaskShortcut = F5

[holon/theme]
class = HolonTheme

[holon/project-task-tree-window]
class = HolonProjectTaskTreeWindow

[holon/open-task-tree-window]
class = HolonOpenTaskTreeWindow

[holon/parameters-window]
class = HolonParametersWindow

[holon/settings-window]
class = HolonSettingsWindow

[holon/messages-window]
class = HolonMessagesWindow

[holon/markupeditor-window]
class = HolonMarkupEditorWindow

[holon/terminal-window]
class = HolonTerminalWindow

[holon/task-folder-a]
class = HolonTaskFolder
title = Branch A

[holon/task-folder-a/custom-task-1]
class = HolonCustomTask
a = value A
parametersWidget = qml/customTaskA.qml
title = Custom Task A

[holon/task-folder-a/custom-task-1/0]
class = HolonTaskStackedWindow

[holon/task-folder-a/custom-task-1/0/2]
class = HolonMarkupEditorWindow

[holon/task-folder-b]
class = HolonTaskFolder
title = Branch B

[holon/task-folder-b/custom-task-2]
class = HolonCustomTask
parametersWidget = python/customTaskWidget.py
title = Custom Task B

[holon/task-folder-b/custom-task-2/0]
class = HolonTaskStackedWindow

[holon/task-folder-b/custom-task-2/0/0]
class = HolonTerminalWindow
title = Terminal

[holon/task-folder-b/custom-task-3]
class = HolonCustomTask
parametersWidget = python/customTaskWidget.py
title = Custom Task C

[holon/task-folder-b/custom-task-3/0]
class = HolonTaskStackedWindow

[holon/task-folder-b/custom-task-3/0/1]
class = HolonTerminalWindow
title = Terminal

[holon/workflow]
class = HolonWorkflow

[holon/workflow/1]
class = HolonWorkflow
current = true
modelState = 0/t,1/y,1/2/t,3/t
title = Workflow 1

[holon/workflow/1/0]
class = HolonCustomTask
a = value A
dockWidgetSplitState = 0/t,1/b
mainWindowState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAALfAAACTvwCAAAAAfwAAAAAAAACTgAAALsA/////AIAAAAC+wAAAAIAMgEAAAAAAAABJwAAAAAAAAAA/AAAAAAAAAJOAAAAuwD////8AgAAAAL7AAAAAgAwAQAAAAAAAAC5AAAAXQD////7AAAAAgAxAQAAALoAAAGUAAAAXQD///8AAAAAAAACTgAAAAQAAAAEAAAACAAAAAj8AAAAAA==)
open = true
parametersWidget = qml/customTaskA.qml
title = Custom Task A

[holon/workflow/1/0/0]
class = HolonTaskStackedWindow

[holon/workflow/1/0/0/1]
class = HolonTerminalWindow

[holon/workflow/1/0/0/0]
class = HolonMarkupEditorWindow
current = true

[holon/workflow/1/0/1]
class = HolonTaskStackedWindow
current = true

[holon/workflow/1/0/1/1]
class = HolonTerminalWindow

[holon/workflow/1/0/1/0]
class = HolonMarkupEditorWindow
current = true

[holon/workflow/1/1]
class = HolonCustomTask
a = value B
dockWidgetSplitState = 0/l,1/r
mainWindowState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAAHMAAACbPwCAAAAAfwAAAAAAAACbAAAAF0A/////AEAAAAC+wAAAAIAMAEAAAAAAAAA5QAAAMgA////+wAAAAIAMQEAAADmAAAA5gAAAOYA////AAAAAAAAAmwAAAAEAAAABAAAAAgAAAAI/AAAAAA=)
open = true
parametersWidget = python/customTaskWidget.py
title = Custom Task B

[holon/workflow/1/1/0]
class = HolonTaskStackedWindow

[holon/workflow/1/1/0/1]
class = HolonTerminalWindow

[holon/workflow/1/1/0/0]
class = HolonMarkupEditorWindow
current = true

[holon/workflow/1/1/1]
class = HolonTaskStackedWindow
current = true

[holon/workflow/1/1/1/1]
class = HolonTerminalWindow

[holon/workflow/1/1/1/0]
class = HolonMarkupEditorWindow
current = true

[holon/workflow/1/2]
class = HolonCustomTask
a = value C1
current = true
dockWidgetSplitState = 0/b,t/1/l,t/2/r
exec = python/customTaskC.py
mainWindowState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAAGtAAACbPwCAAAAAfwAAAAAAAACbAAAALsA/////AIAAAAC/AAAAAAAAAGtAAAAXQD////8AQAAAAL7AAAAAgAxAQAAAAAAAADWAAAAyAD////7AAAAAgAyAQAAANcAAADWAAAAyAD////7AAAAAgAwAQAAAa4AAAC+AAAAXQD///8AAAAAAAACbAAAAAQAAAAEAAAACAAAAAj8AAAAAA==)
open = true
parametersWidget = python/customTaskWidget.py
title = Custom Task C

[holon/workflow/1/2/1]
class = HolonTaskStackedWindow

[holon/workflow/1/2/1/1]
class = HolonTerminalWindow

[holon/workflow/1/2/1/0]
class = HolonMarkupEditorWindow
current = true

[holon/workflow/1/2/0]
class = HolonTaskStackedWindow
current = true

[holon/workflow/1/2/0/1]
class = HolonTerminalWindow
current = true

[holon/workflow/1/2/2]
class = HolonTaskStackedWindow

[holon/workflow/1/2/2/0]
class = HolonMarkupEditorWindow
current = true

[holon/workflow/1/3]
class = HolonCustomTask
a = value C2
dockWidgetSplitState = 1/t,0/b
mainWindowState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAALfAAACTvwCAAAAAfwAAAAAAAACTgAAALsA/////AEAAAAC/AAAAAAAAALfAAAAwQD////8AgAAAAL7AAAAAgAxAQAAAAAAAACqAAAAXQD////7AAAAAgAwAQAAAKsAAAGjAAAAXQD////7AAAAAgAyAQAAAhQAAADLAAAAAAAAAAAAAAAAAAACTgAAAAQAAAAEAAAACAAAAAj8AAAAAA==)
open = true
parametersWidget = python/customTaskWidget.py
title = Custom Task C

[holon/workflow/1/3/1]
class = HolonTaskStackedWindow
current = true

[holon/workflow/1/3/1/1]
class = HolonTerminalWindow
current = true
title = Terminal

[holon/workflow/1/3/0]
class = HolonTaskStackedWindow

[holon/workflow/1/3/0/1]
class = HolonTerminalWindow
current = true
title = Terminal

[holon/workflow/2]
class = HolonWorkflow
title = Workflow 2

[holon/shell]
class = QLoaderShell
home = holon/shell

[holon/shell/cd]
class = QLoaderShellCd

[holon/shell/exit]
class = QLoaderShellExit

[holon/shell/save]
class = QLoaderShellSave

[holon/tasks]
class = HolonSidebar
area = left
checked = true
dockWidgetSplitState = 1/b,0/t
mainWindowNestingIndex = 0
mainWindowNestingState = QByteArray(AAAA/wAAAAD9AAAAAgAAAAAAAADAAAACyfwCAAAAAfsAAAAKAHQAYQBzAGsAcwEAAAAAAAACyQAAALoA///+AAAAAQAAALEAAALJ/AIAAAAB+wAAABAAcwBlAHQAdABpAG4AZwBzAQAAAAAAAALJAAAAKQD///4AAAKWAAACyQAAAAQAAAAEAAAACAAAAAj8AAAAAA==)
mainWindowState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAADAAAACyfwCAAAAAfwAAAAAAAACyQAAALsA/////AIAAAAC/AAAAAAAAAFrAAAAXQD////8AgAAAAL7AAAAAgAwAQAAAAAAAAFrAAAAXQD////7AAAAAgAyAQAAAOAAAADfAAAAAAAAAAD7AAAAAgAxAQAAAWwAAAFdAAAAXQD///8AAAAAAAACxwAAAAQAAAAEAAAACAAAAAj8AAAAAA==)
shortcut = Alt+1
title = 1  Tasks

[holon/tasks/0]
class = HolonStackedWindow

[holon/tasks/0/0]
class = HolonProjectTaskTreeWindow
current = true

[holon/tasks/1]
class = HolonStackedWindow

[holon/tasks/1/0]
class = HolonProjectTaskTreeWindow

[holon/tasks/1/1]
class = HolonOpenTaskTreeWindow
current = true

[holon/parameters]
class = HolonSidebar
area = left
checked = true
mainWindowNestingIndex = 1
mainWindowNestingState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAADoAAACyfwCAAAAAfsAAAAUAHAAYQByAGEAbQBlAHQAZQByAHMBAAAAAAAAAskAAABDAP///gAAAc0AAALJAAAABAAAAAQAAAAIAAAACPwAAAAA)
shortcut = Alt+2
title = 2  Parameters

[holon/parameters/window]
class = HolonParametersWindow

[holon/workflow-window-area]
class = HolonWindowArea
area = bottom
dockWidgetSplitState = 0/l,1/r
mainWindowState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAAAAAGtAAACbPwCAAAAAfwAAAAAAAACbAAAAF0A/////AEAAAAC+wAAAAIAMAEAAAAAAAAAwAAAAMAA////+wAAAAIAMQEAAADBAAAA7AAAAMAA////AAAAAAAAAmwAAAAEAAAABAAAAAgAAAAI/AAAAAA=)
shortcut = Alt+3
title = 3  Workflows

[holon/workflow-window-area/0]
class = HolonWorkflowWindow
current = true
treeView = true
workflowId = 2

[holon/workflow-window-area/1]
class = HolonWorkflowWindow
treeView = true
workflowId = 1

[holon/messages]
class = HolonSidebar
area = bottom
checked = true
mainWindowNestingIndex = 2
mainWindowNestingState = QByteArray(AAAA/wAAAAD9AAAAAQAAAAMAAAGtAAAAXPwBAAAAAfsAAAAQAG0AZQBzAHMAYQBnAGUAcwEAAAAAAAABrQAAAIMA////AAABrQAAAmwAAAAEAAAABAAAAAgAAAAI/AAAAAA=)
shortcut = Alt+4
title = 4  Messages

[holon/messages/window]
class = HolonMessagesWindow

[holon/settings]
class = HolonSidebar
area = right
checked = true
mainWindowNestingIndex = 0
shortcut = Alt+5
title = 5  Settings

[holon/settings/window]
class = HolonSettingsWindow
